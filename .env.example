# Turso Database Configuration
# Get these from your Turso dashboard (turso db show <db-name>)
TURSO_DATABASE_URL=libsql://your-db-name-your-user.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# For local development, if these are not set, it defaults to:
# file:jobs.sqlite

# Secret token to protect the /api/scrape endpoint (only you should know this)
# To trigger a manual scrape: curl -X POST https://your-site.com/api/scrape \
#   -H "Authorization: Bearer <your-secret>"
SCRAPE_SECRET=your-strong-secret-here
